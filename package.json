{
  "name": "aether-cinema",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev -p 3010\" \"node server/index.js\"",
    "dev:next": "next dev -p 3010",
    "dev:ws": "node server/index.js",
    "build": "next build",
    "start": "concurrently \"next start -p 3000\" \"node server/index.js\"",
    "start:prod": "node server/index.js & next start -p 3000"
  },
  "dependencies": {
    "artplayer": "^5.4.0",
    "concurrently": "^9.2.1",
    "cookie": "^1.1.1",
    "jose": "^6.2.2",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "postcss": "^8",
    "tailwindcss": "^3.4.1"
  }
}
